#compdef rusty-ts

autoload -U is-at-least

_rusty-ts() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'(-u --utc)--tz=[Render timestamps in the named IANA timezone (e.g., \`America/New_York\`). Resolved once at startup; per-line render cost is a fixed-offset conversion. Rejected in Strict mode]:IANA-NAME:_default' \
'(-s --since-start)-i[Render elapsed time since the previous input line instead of absolute time]' \
'(-s --since-start)--incremental[Render elapsed time since the previous input line instead of absolute time]' \
'(-i --incremental)-s[Render elapsed time since program start instead of absolute time]' \
'(-i --incremental)--since-start[Render elapsed time since program start instead of absolute time]' \
'-m[Use a monotonic clock source for elapsed-time calculations. Has no effect unless \`-i\` or \`-s\` is also present]' \
'--monotonic[Use a monotonic clock source for elapsed-time calculations. Has no effect unless \`-i\` or \`-s\` is also present]' \
'-r[Convert recognized in-line timestamps to relative form rather than prefixing new timestamps. Default mode recognizes ISO-8601, RFC-3339, and Unix epoch; Strict mode expands to the full moreutils set]' \
'--relative[Convert recognized in-line timestamps to relative form rather than prefixing new timestamps. Default mode recognizes ISO-8601, RFC-3339, and Unix epoch; Strict mode expands to the full moreutils set]' \
'(--tz)-u[Force timestamps to be rendered in UTC, overriding system local time and the \`TZ\` env var. Rejected in Strict mode]' \
'(--tz)--utc[Force timestamps to be rendered in UTC, overriding system local time and the \`TZ\` env var. Rejected in Strict mode]' \
'(--no-strict)--strict[Switch into Strict moreutils Compatibility Mode. Rejects \`-u\`, \`--tz\`, and other Rusty-only flags; expands \`-r\` to the full moreutils set; mirrors moreutils \`--help\` / \`--version\` layout; ignores \`RUSTY_TS_FORMAT\`]' \
'(--strict)--no-strict[Force Default mode, overriding \`RUSTY_TS_STRICT\` env var and argv\[0\] auto-detection]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::format -- Optional strftime format string. If omitted, uses the moreutils default format (`%b %d %H\:%M\:%S`) or the `RUSTY_TS_FORMAT` env var (Default mode only). A positional argument always wins over the env var:_default' \
":: :_rusty-ts_commands" \
"*::: :->rusty-ts" \
&& ret=0
    case $state in
    (rusty-ts)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:rusty-ts-command-$line[2]:"
        case $line[2] in
            (completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Target shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_rusty-ts__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:rusty-ts-help-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_rusty-ts_commands] )) ||
_rusty-ts_commands() {
    local commands; commands=(
'completions:Generate shell-completion scripts for bash, zsh, fish, or powershell. Writes to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'rusty-ts commands' commands "$@"
}
(( $+functions[_rusty-ts__subcmd__completions_commands] )) ||
_rusty-ts__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'rusty-ts completions commands' commands "$@"
}
(( $+functions[_rusty-ts__subcmd__help_commands] )) ||
_rusty-ts__subcmd__help_commands() {
    local commands; commands=(
'completions:Generate shell-completion scripts for bash, zsh, fish, or powershell. Writes to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'rusty-ts help commands' commands "$@"
}
(( $+functions[_rusty-ts__subcmd__help__subcmd__completions_commands] )) ||
_rusty-ts__subcmd__help__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'rusty-ts help completions commands' commands "$@"
}
(( $+functions[_rusty-ts__subcmd__help__subcmd__help_commands] )) ||
_rusty-ts__subcmd__help__subcmd__help_commands() {
    local commands; commands=()
    _describe -t commands 'rusty-ts help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_rusty-ts" ]; then
    _rusty-ts "$@"
else
    compdef _rusty-ts rusty-ts
fi
